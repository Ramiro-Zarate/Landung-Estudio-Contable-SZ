---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'Estudio Contable SZ | Asesoría Contable, Impositiva y Laboral',
  description = 'Estudio Contable SZ: +20 años ofreciendo servicios contables, impositivos y laborales para empresas y profesionales en Buenos Aires. Asesoramiento integral, personalizado y confiable.',
  canonical = Astro.url.href,
  ogImage = new URL('/logo_estudio.webp', Astro.site).href,
  ogImageAlt = 'Estudio Contable SZ',
  jsonLd,
} = Astro.props;

const siteName = 'Estudio Contable SZ';
const locale = 'es_AR';
const jsonLdArray = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#9d1a15" />
<meta name="color-scheme" content="light" />
<meta name="robots" content="index, follow, max-image-preview:large" />

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/logo_estudio.webp" />

<meta property="og:type" content="website" />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content={locale} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAlt} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={ogImageAlt} />

{jsonLdArray.map((data) => (
  <script type="application/ld+json" set:html={JSON.stringify(data)} />
))}
