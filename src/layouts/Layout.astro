---
import '../styles/global.css';
import fondoMainWebp from '../assets/fondo_main.webp';
---
<!doctype html>
<html lang="es">
	<head>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet">
		<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
		<link rel="preload" as="image" href={fondoMainWebp.src} type="image/webp" fetchpriority="high" />
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="En Estudio Contable SZ, ofrecemos servicios contables y fiscales personalizados para pequeñas y medianas empresas. Nuestro equipo de expertos se dedica a ayudarte a alcanzar tus objetivos financieros con soluciones integrales y un enfoque centrado en el cliente." />
		<link rel="icon" href="/logo_estudio.jpg" />
		<meta name="generator" content={Astro.generator} />
		<title>Estudio SZ | Asesoría Contable, Impositiva y Laboral</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}
</style>
